{
  "name": "event-search",
  "version": "1.0.0",
  "description": "Modular TypeScript scraper for brewery/winery/restaurant event pages",
  "main": "dist/index.js",
  "bin": {
    "event-scrape": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "scrape": "ts-node src/cli/index.ts",
    "validate": "ts-node src/cli/index.ts validate",
    "test-scraper": "ts-node src/cli/index.ts test-scraper",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "scraper",
    "events",
    "brewery",
    "winery",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.12.0",
    "axios-retry": "^4.5.0",
    "cheerio": "^1.0.0",
    "commander": "^14.0.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "ical-generator": "^10.0.0",
    "playwright": "^1.55.0",
    "winston": "^3.17.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.4.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.9.0"
  }
}
